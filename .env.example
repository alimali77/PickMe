# ============================================================
# Pick Me — env.example
# Gerçek .env dosyası repo'ya eklenmez. Bu dosya SADECE şablon.
# ============================================================

# ---------- URL'ler ----------
API_BASE_URL=https://localhost:5001
FRONTEND_BASE_URL=https://localhost:5173
# Virgülle ayrılmış liste
CORS_ORIGINS=https://localhost:5173,https://localhost:4173

# ---------- Database ----------
# Windows dev makinesi — SQL Server LocalDB (kullanıcı tercihi):
DB_CONNECTION_STRING=Server=(localdb)\MSSQLLocalDB;Database=PickMeDB;Integrated Security=true;TrustServerCertificate=true;
# Prod (IIS sunucusu, SQL auth) örneği:
# DB_CONNECTION_STRING=Server=localhost,1433;Database=PickMeDB;User Id=pickme_app;Password=ChangeMe_Str0ng!;TrustServerCertificate=True;

# ---------- JWT ----------
# Minimum 32 karakter (256 bit). Prod'da en az 64 karakterlik random string kullan.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits-long!!
JWT_ISSUER=pickme-api
JWT_AUDIENCE=pickme-web
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# ---------- SMTP ----------
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@pickme.local
SMTP_FROM_NAME=Pick Me
SMTP_ENABLE_SSL=false

# ---------- Google Maps ----------
# Bu değer browser'a expose olur. Google Cloud Console'da HTTP referrer restriction aktif olmalı.
GOOGLE_MAPS_API_KEY=

# ---------- Google Analytics 4 ----------
GA4_ID=

# ---------- İlk admin seed ----------
SEED_ADMIN_EMAIL=admin@pickme.local
SEED_ADMIN_PASSWORD=Admin123!Change
SEED_ADMIN_FULL_NAME=Sistem Yöneticisi

# ---------- WhatsApp / iletişim ----------
# Uluslararası format, + işareti olmadan (ör: 905551234567)
WHATSAPP_NUMBER=905551234567
CONTACT_EMAIL=info@pickme.local
CONTACT_PHONE=+90 (555) 123 45 67
CONTACT_ADDRESS=İstanbul, Türkiye
WORKING_HOURS=7/24

# ---------- Güvenlik ----------
BCRYPT_COST=12

# ---------- Rate limit ----------
RATE_LIMIT_LOGIN_PER_10MIN=10
RATE_LIMIT_REGISTER_PER_HOUR=5
RATE_LIMIT_FORGOT_PER_HOUR=3
RATE_LIMIT_CONTACT_PER_HOUR=3
RATE_LIMIT_GENERAL_PER_MIN=120
