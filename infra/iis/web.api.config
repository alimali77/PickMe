<?xml version="1.0" encoding="utf-8"?>
<!--
  Pick Me — ASP.NET Core API için IIS web.config.
  Kurulum dizini örneği: C:\inetpub\pickme\api
  Gerekli: .NET 10 Hosting Bundle + URL Rewrite Module + (opsiyonel) ARR
  Environment variable'lar sistem ya da IIS "Configuration Editor" üzerinden
  ayarlanmalıdır — hassas değerleri burada plaintext tutmayınız.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore
        processPath="dotnet"
        arguments=".\PickMe.Api.dll"
        stdoutLogEnabled="false"
        stdoutLogFile=".\logs\stdout"
        hostingModel="inprocess"
        requestTimeout="00:02:00">
        <environmentVariables>
          <!-- Prod'da bu alanları gerçek değerlerle doldurun (hassas olanları IIS Config Editor ile encrypt edin) -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="ASPNETCORE_URLS" value="http://localhost:5080" />
          <!--
          <environmentVariable name="DB_CONNECTION_STRING" value="Server=...;Database=PickMeDB;..." />
          <environmentVariable name="JWT_SECRET" value="prod-secret-min-256-bit" />
          <environmentVariable name="JWT_ISSUER" value="pickme-api" />
          <environmentVariable name="JWT_AUDIENCE" value="pickme-web" />
          <environmentVariable name="CORS_ORIGINS" value="https://pickme.example" />
          <environmentVariable name="FRONTEND_BASE_URL" value="https://pickme.example" />
          <environmentVariable name="SMTP_HOST" value="smtp.example.com" />
          <environmentVariable name="SMTP_PORT" value="587" />
          <environmentVariable name="SMTP_USER" value="no-reply@pickme.example" />
          <environmentVariable name="SMTP_PASS" value="..." />
          <environmentVariable name="SMTP_FROM" value="no-reply@pickme.example" />
          <environmentVariable name="SMTP_ENABLE_SSL" value="true" />
          <environmentVariable name="SEED_ADMIN_EMAIL" value="admin@pickme.example" />
          <environmentVariable name="SEED_ADMIN_PASSWORD" value="(bir kere, sonra değiştirilecek)" />
          <environmentVariable name="HANGFIRE_ENABLED" value="true" />
          <environmentVariable name="BCRYPT_COST" value="12" />
          -->
        </environmentVariables>
      </aspNetCore>

      <!-- Response compression (IIS seviyesi) -->
      <httpCompression>
        <staticTypes>
          <add mimeType="application/json" enabled="true" />
          <add mimeType="text/plain" enabled="true" />
        </staticTypes>
      </httpCompression>

      <!-- Güvenlik header'ları (backend middleware ayrıca yazıyor ama IIS seviyesi de güvenlidir) -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        </customHeaders>
      </httpProtocol>

      <!-- İstek boyutu limit (dosya upload olmadığı için 4MB yeter) -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="4194304" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
